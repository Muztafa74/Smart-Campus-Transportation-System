# Copy to config/.env and fill in real values (never commit .env).

PORT=5000
NODE_ENV=production

# MongoDB Atlas (replace USER, PASSWORD, cluster host)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/smart_campus_transport?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Browser origins allowed to call the API (comma-separated). Required for Vercel SPA.
# Example:
# CORS_ORIGINS=https://smart-campus-transportation-system.vercel.app
# Optional: allow Vercel preview URLs (*.vercel.app)
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Public URL of this API (origin only, no /api). Used in startup logs and Swagger.
# Example: https://smart-campus-api.onrender.com
# API_PUBLIC_URL=

# HOST=0.0.0.0
# TRUST_PROXY=true
